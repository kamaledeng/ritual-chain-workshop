# --- AI Bounty Judge / Ritual Chain ---
# Copy this file to `.env.local` and fill in the values.

# Deployed AIBountyJudge contract address (0x...)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Ritual Chain JSON-RPC endpoint
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Ritual Chain numeric chain id
NEXT_PUBLIC_RITUAL_CHAIN_ID=1979

# Registered Ritual LLM TEE executor used to build the `judgeAll` request.
# Verified against TEEServiceRegistry capability 1 on 2026-06-25; re-check it
# before a live demo because executor validity can change.
NEXT_PUBLIC_RITUAL_EXECUTOR_ADDRESS=0xB42e435c4252A5a2E7440e37B609F00c61a0c91B

# Optional: WalletConnect project id. Leave empty to use injected wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
